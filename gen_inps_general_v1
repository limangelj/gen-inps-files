#!/usr/bin/env python3
from pathlib import Path
import argparse
import sys
import os

B3LYP_OPT_TEMPLATE = """\
! B3LYP def2-TZVP def2/J RIJCOSX D3BJ TightSCF TightOpt DefGrid2 CPCM({solvent})
%maxcore 1000
%pal nprocs 1 end
%geom
  MaxIter 500
end
* xyzfile {charge} {mult} {xyz}
"""

B3LYP_FREQ_TEMPLATE = """\
! B3LYP def2-TZVP def2/J RIJCOSX D3BJ TightSCF AnFreq DefGrid2 CPCM({solvent})
%maxcore 1000
%pal nprocs 1 end
* xyzfile {charge} {mult} {xyz}
"""

CAM_B3LYP_TDDFT_TEMPLATE = """\
! CAM-B3LYP def2-TZVP def2/J RIJCOSX TightSCF DefGrid2 CPCM({solvent})
%maxcore 1000
%pal nprocs 1 end
%tddft
  nroots 6
  tda false
  triplets false
  maxdim 5
end
* xyzfile {charge} {mult} {xyz}
"""

WB97XD3_TDDFT_TEMPLATE = """\
! wB97X-D3 def2-TZVP def2/J RIJCOSX TightSCF DefGrid2 CPCM({solvent})
%maxcore 1000
%pal nprocs 1 end
%tddft
  nroots 6
  tda true
  triplets false
  maxdim 5
end
* xyzfile {charge} {mult} {xyz}
"""

DLPNO_STEOM_CCSD_TEMPLATE = """\
! DLPNO-STEOM-CCSD def2-TZVP def2-TZVP/C RIJCOSX TightSCF
%maxcore 1000
%pal nprocs 1 end
%cpcm
  solvent "{solvent}"
end
%mdci
  NRoots 5
  NActIP 8
  NActEA 6
  DoCISNat false
  DoRootWise false
  OThresh 0.005
  VThresh 0.005
  TCutPNOSingles 1e-11
  NDAV 400
  MaxIter 300
  DTol 1e-5
  DoSimpleDens false
  AddL2Term true
end
* xyzfile {charge} {mult} {xyz}
"""

RUN_TEMPLATE = """\
#!/bin/bash
# Stage 1: geometry optimization
opt_jid=$(qorca -i ./{opt_file} -c {cores} -m 2500)

# Stage 2: freq + TDDFT in parallel, all depend on opt
freq_jid=$(qorca -i ./{freq_file} -c {cores} -m 2500 -n 1 -j ${{opt_jid}})
cam_jid=$(qorca -i ./{cam_tddft_file} -c {cores} -m 2500 -j ${{opt_jid}})
wb97_jid=$(qorca -i ./{wb97_tddft_file} -c {cores} -m 2500 -j ${{opt_jid}})

# Stage 3: DLPNO depends on all stage 2 jobs finishing
dlpno_jid=$(qorca -i ./{dlpno_file} -c {cores} -m 8000 -d 6000 -n 1 -j ${{cam_jid}}:${{wb97_jid}}:${{freq_jid}})
"""


def parse_args():
    parser = argparse.ArgumentParser(
        description="Generate ORCA input files and submission scripts",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )
    parser.add_argument("name", help="Base name for output files")
    parser.add_argument("xyz", help="Input .xyz file")
    parser.add_argument("charge", type=int, help="Molecule net charge")
    parser.add_argument("--mult", type=int, default=1,
                        help="Spin multiplicity")
    parser.add_argument("-s", "--solvent", default="water",
                        help="Solvent name for CPCM (e.g. water, acetonitrile, dichloromethane)")
    parser.add_argument("-c", "--cores", type=int, default=16,
                        help="Number of CPU cores requested from the scheduler (qorca -c)")
    return parser.parse_args()


def check_xyz(xyz_path: Path):
    if not xyz_path.exists():
        print(f"Error: {xyz_path} not found.")
        sys.exit(1)
    if xyz_path.suffix != ".xyz":
        print("Error: input file must have .xyz extension.")
        sys.exit(1)


def write_file(path: Path, content: str, executable: bool = False):
    path.write_text(content)
    if executable:
        os.chmod(path, 0o755)
    print(f"  Written: {path}")


def main():
    args = parse_args()
    xyz_path = Path(args.xyz)
    check_xyz(xyz_path)

    stem = args.name
    cores = args.cores

    # --- File paths ---
    opt_stem = f"{stem}_b3lyp_def2-tzvp_opt"
    opt_file = Path(opt_stem + ".inp")
    opt_xyz = Path(opt_stem + ".xyz")  # ORCA output geometry

    freq_file       = Path(f"{stem}_b3lyp_def2-tzvp_freq.inp")
    cam_tddft_file  = Path(f"{stem}_cam-b3lyp_def2-tzvp_tddft.inp")
    wb97_tddft_file = Path(f"{stem}_wb97x-d3_def2-tzvp_tddft.inp")
    dlpno_file      = Path(f"{stem}_dlpno_steom_ccsd.inp")
    run_file        = Path(f"run_{stem}.sh")

    # --- Shared format kwargs ---
    base_kwargs = dict(
        charge=args.charge,
        mult=args.mult,
        solvent=args.solvent,
    )

    # --- Write ORCA inputs ---
    print("Generating ORCA input files...")

    write_file(opt_file, B3LYP_OPT_TEMPLATE.format(
        xyz=xyz_path.name, **base_kwargs
    ))
    write_file(freq_file, B3LYP_FREQ_TEMPLATE.format(
        xyz=opt_xyz, **base_kwargs
    ))
    write_file(cam_tddft_file, CAM_B3LYP_TDDFT_TEMPLATE.format(
        xyz=opt_xyz, **base_kwargs
    ))
    write_file(wb97_tddft_file, WB97XD3_TDDFT_TEMPLATE.format(
        xyz=opt_xyz, **base_kwargs
    ))
    write_file(dlpno_file, DLPNO_STEOM_CCSD_TEMPLATE.format(
        xyz=opt_xyz, **base_kwargs
    ))

    # --- Write run script ---
    print("Generating run script...")

    write_file(run_file, RUN_TEMPLATE.format(
        opt_file=opt_file,
        freq_file=freq_file,
        cam_tddft_file=cam_tddft_file,
        wb97_tddft_file=wb97_tddft_file,
        dlpno_file=dlpno_file,
        cores=cores,
        mem=mem,
        dlpno_mem=mem + 2,
    ), executable=True)

    print("\nDone! Workflow summary:")
    print(f"  Submit: {run_file}")
    print(f"  Chain:  opt → freq + CAM-B3LYP + wB97X-D3 (parallel) → DLPNO")


if __name__ == "__main__":
    main()
