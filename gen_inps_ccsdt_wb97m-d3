#!/usr/bin/env python3
from pathlib import Path
import argparse
import sys
import os

S0_OPT_TEMPLATE = """\
! wB97M-D3BJ def2-TZVP def2/J RIJCOSX TightSCF TightOpt FREQ CPCM({solvent})
%maxcore 1000
%pal nprocs {cores} end
%geom
  MaxIter 500
end
* xyzfile {charge} {mult} {xyz}
"""

T1_OPT_TEMPLATE = """\
! UHF wB97M-D3BJ def2-TZVP def2/J RIJCOSX TightSCF TightOpt FREQ CPCM({solvent})
%maxcore 1000
%pal nprocs {cores} end
%scf
  HFTyp UHF
end
%geom
  MaxIter 500
end
* xyzfile {charge} {mult} {xyz}
"""

CCSD_S0GEOM_TEMPLATE = """\
! DLPNO-CCSD(T) cc-pVDZ cc-pVDZ/C AutoAux NormalPNO TightSCF CPCM({solvent})
%maxcore 7125
%pal nprocs 8 end
* xyzfile {charge} {mult} {xyz}
"""

CCSD_T1GEOM_TEMPLATE = """\
! UHF DLPNO-CCSD(T) cc-pVDZ cc-pVDZ/C AutoAux NormalPNO TightSCF CPCM({solvent})
%maxcore 7125
%pal nprocs 8 end
%scf
  HFTyp UHF
end
* xyzfile {charge} {mult} {xyz}
"""

RUN_TEMPLATE = """\
#!/bin/bash
# Stage 1: geometry optimization (parallel)
s0_opt_jid=$(qorca -i ./{s0_opt_file} -c {cores} -m 2500)
t1_opt_jid=$(qorca -i ./{t1_opt_file} -c {cores} -m 2500)
# Stage 2: CCSD(T) single points (parallel, each waiting on its own opt)
s0_ccsd_jid=$(qorca -i ./{ccsd_s0geom_file} -c 8 -m 9500 -d 2000 -n 1 -p highres -j ${{s0_opt_jid}})
t1_ccsd_jid=$(qorca -i ./{ccsd_t1geom_file} -c 8 -m 9500 -d 2000 -n 1 -p highres -j ${{t1_opt_jid}})
"""

def check_xyz(xyz_path: Path):
    if not xyz_path.exists():
        print(f"Error: {xyz_path} not found.")
        sys.exit(1)
    if xyz_path.suffix != ".xyz":
        print("Error: input must be .xyz")
        sys.exit(1)

def write_file(path: Path, content: str, executable: bool = False):
    path.write_text(content)
    if executable:
        os.chmod(path, 0o755)
    print(f"  Written: {path}")

def main():
    parser = argparse.ArgumentParser(
        description="Generate ORCA wB97M-D3 opt + DLPNO-CCSD(T) inputs and run script",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )
    parser.add_argument("name",   help="Base name for output files")
    parser.add_argument("xyz",    help="Input .xyz file")
    parser.add_argument("charge", type=int, help="Molecule net charge")
    parser.add_argument("--mult", type=int, default=1,
                        help="Ground state spin multiplicity")
    parser.add_argument("-c", "--cores", type=int, default=16,
                        help="Number of CPU cores for opt/freq jobs")
    parser.add_argument("-s", "--solvent", default="water",
                        help="Solvent name for CPCM (e.g. water, acetonitrile, dichloromethane)")
    args = parser.parse_args()

    xyz_path = Path(args.xyz)
    check_xyz(xyz_path)

    stem    = args.name
    solvent = args.solvent
    cores   = args.cores

    # --- File paths ---
    s0_opt_stem = f"{stem}_{solvent}_wb97m-d3_def2-tzvp_s0_opt"
    s0_opt_file = Path(s0_opt_stem + ".inp")
    s0_opt_xyz  = Path(s0_opt_stem + ".xyz")

    t1_opt_stem = f"{stem}_{solvent}_wb97m-d3_def2-tzvp_t1_opt"
    t1_opt_file = Path(t1_opt_stem + ".inp")
    t1_opt_xyz  = Path(t1_opt_stem + ".xyz")

    ccsd_s0geom_file = Path(f"{stem}_{solvent}_wb97m-d3_opt_dlpno_ccsdt_s0geom.inp")
    ccsd_t1geom_file = Path(f"{stem}_{solvent}_wb97m-d3_opt_dlpno_ccsdt_t1geom.inp")
    run_file         = Path(f"run_{stem}_{solvent}_wb97m_dlpno_ccsdt.sh")

    # --- Write ORCA inputs ---
    print("Generating ORCA input files...")

    write_file(s0_opt_file, S0_OPT_TEMPLATE.format(
        charge=args.charge, mult=args.mult, xyz=xyz_path.name, solvent=solvent, cores=cores
    ))
    write_file(t1_opt_file, T1_OPT_TEMPLATE.format(
        charge=args.charge, mult=3, xyz=xyz_path.name, solvent=solvent, cores=cores
    ))
    write_file(ccsd_s0geom_file, CCSD_S0GEOM_TEMPLATE.format(
        charge=args.charge, mult=args.mult, xyz=s0_opt_xyz, solvent=solvent
    ))
    write_file(ccsd_t1geom_file, CCSD_T1GEOM_TEMPLATE.format(
        charge=args.charge, mult=3, xyz=t1_opt_xyz, solvent=solvent
    ))

    # --- Write run script ---
    print("Generating run script...")

    write_file(run_file, RUN_TEMPLATE.format(
        s0_opt_file=s0_opt_file,
        t1_opt_file=t1_opt_file,
        ccsd_s0geom_file=ccsd_s0geom_file,
        ccsd_t1geom_file=ccsd_t1geom_file,
        cores=cores,
    ), executable=True)

    print("\nDone! Workflow summary:")
    print(f"  Submit:  {run_file}")
    print(f"  S0 opt:  {s0_opt_file}")
    print(f"  T1 opt:  {t1_opt_file}")
    print(f"  S0 CCSD(T): {ccsd_s0geom_file}")
    print(f"  T1 CCSD(T): {ccsd_t1geom_file}")
    print(f"  Chain:   S0/T1 opt (parallel) → S0/T1 CCSD(T) (parallel)")

if __name__ == "__main__":
    main()
