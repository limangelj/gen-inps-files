#!/usr/bin/env python3
"""
Compute Dexter Energy Transfer (DET) orbital overlaps for ZnP/PMI at x=0.

Mode A: separate molecule calculations, cube file overlaps.
Donor:    ZnP  T1 SP -> SOMO-1 = pi_D,  SOMO = pi*_D
Acceptor: PMI  T1 SP -> SOMO-1 = pi_A,  SOMO = pi*_A

Visualisation: 2 panels showing both molecules side by side.
  Left:  pi_D (ZnP) + pi_A  (PMI)  — shows S(pi_D, pi_A)
  Right: pi*_D(ZnP) + pi*_A (PMI)  — shows S(pi*_D, pi*_A)
  Title: V_DET = S_pi x S_pi*

Outputs:
    - Terminal: overlap integrals and V_DET
    - HTML:     interactive 3D dimer MO visualisation uploaded to GCS
"""

import numpy as np
from scipy.interpolate import RegularGridInterpolator

# ------------------------------------------------------------
# CUBE FILE PATHS
# ------------------------------------------------------------
CUBE_PI_D     = "/nfs/outputs/dexter_cal/ZnP-PMI/znp_cam-b3lyp_def2-TZVP_t1_sp.mo174a.cube"
CUBE_PISTAR_D = "/nfs/outputs/dexter_cal/ZnP-PMI/znp_cam-b3lyp_def2-TZVP_t1_sp.mo175a.cube"
CUBE_PI_A     = "/nfs/outputs/dexter_cal/ZnP-PMI/PMI_cam-b3lyp_def2-TZVP_s0_opt_t1_sp.mo194a.cube"
CUBE_PISTAR_A = "/nfs/outputs/dexter_cal/ZnP-PMI/PMI_cam-b3lyp_def2-TZVP_s0_opt_t1_sp.mo195a.cube"

# ------------------------------------------------------------
# GEOMETRY PARAMETERS
# ------------------------------------------------------------
EDGE_TO_EDGE_DIST = 2.0
ISOVAL            = 0.03
OUTPUT_HTML       = "/nfs/outputs/dexter_cal/ZnP-PMI/mo_visualisation_modeA.html"

ZNP_ANCHOR = np.array([15.6442,  0.5321, -10.0939])
PMI_ANCHOR = np.array([-3.9594, -0.8593,  -1.1577])


# ------------------------------------------------------------
# CUBE FILE READER
# ------------------------------------------------------------

def read_cube(filepath):
    with open(filepath) as f:
        lines = f.readlines()
    natoms = abs(int(lines[2].split()[0]))
    origin = np.array([float(x) for x in lines[2].split()[1:4]]) * 0.529177
    npts = np.zeros(3, dtype=int)
    axes = np.zeros((3, 3))
    for i in range(3):
        p = lines[3+i].split()
        npts[i]   = int(p[0])
        axes[i,:] = [float(x) * 0.529177 for x in p[1:4]]
    expected = npts[0] * npts[1] * npts[2]
    vals = []
    for line in lines[6+natoms:]:
        parts = line.split()
        if not parts:
            continue
        if len(parts) <= 2:
            try:
                [int(x) for x in parts]
                continue
            except ValueError:
                pass
        vals.extend([float(x) for x in parts])
    field = np.array(vals[:expected]).reshape(npts[0], npts[1], npts[2])
    return origin, axes, npts, field


def get_grid_coords(origin, axes, npts):
    x = origin[0] + np.arange(npts[0]) * axes[0, 0]
    y = origin[1] + np.arange(npts[1]) * axes[1, 1]
    z = origin[2] + np.arange(npts[2]) * axes[2, 2]
    return x, y, z


def voxel_volume(axes):
    return abs(np.dot(axes[0], np.cross(axes[1], axes[2])))


def get_mol_coords_from_cube(filepath):
    ELEM_NUM = {1: 'H', 6: 'C', 7: 'N', 8: 'O', 30: 'Zn'}
    with open(filepath) as f:
        lines = f.readlines()
    natoms = abs(int(lines[2].split()[0]))
    coords, elems = [], []
    for line in lines[6:6+natoms]:
        parts = line.split()
        if len(parts) < 5:
            continue
        elem = ELEM_NUM.get(int(parts[0]), 'X')
        coords.append([float(parts[2]) * 0.529177,
                       float(parts[3]) * 0.529177,
                       float(parts[4]) * 0.529177])
        elems.append(elem)
    return np.array(coords), elems


def shift_and_interpolate(field_a, x_a, y_a, z_a, x_d, y_d, z_d, target_dist):
    target = np.array([ZNP_ANCHOR[0] + target_dist,
                       ZNP_ANCHOR[1], ZNP_ANCHOR[2]])
    dx = target[0] - PMI_ANCHOR[0]
    dy = target[1] - PMI_ANCHOR[1]
    dz = target[2] - PMI_ANCHOR[2]
    interp = RegularGridInterpolator(
        (x_a + dx, y_a + dy, z_a + dz), field_a,
        method='linear', bounds_error=False, fill_value=0.0
    )
    X, Y, Z = np.meshgrid(x_d, y_d, z_d, indexing='ij')
    pts = np.stack([X.ravel(), Y.ravel(), Z.ravel()], axis=-1)
    return interp(pts).reshape(len(x_d), len(y_d), len(z_d)), dx, dy, dz


def normalisation(field, dV):
    return np.sum(field**2) * dV


def compute_overlap(field_d, field_a, dV):
    return np.sum(field_d * field_a) * dV


# ------------------------------------------------------------
# VISUALISATION — 2 side-by-side dimer panels
# ------------------------------------------------------------

def make_isosurface(x, y, z, field, isoval, color, opacity, name):
    from skimage.measure import marching_cubes
    import plotly.graph_objects as go
    try:
        verts, faces, _, _ = marching_cubes(
            field, level=isoval,
            spacing=(x[1]-x[0], y[1]-y[0], z[1]-z[0])
        )
        verts[:,0] += x[0]; verts[:,1] += y[0]; verts[:,2] += z[0]
        return go.Mesh3d(
            x=verts[:,0], y=verts[:,1], z=verts[:,2],
            i=faces[:,0], j=faces[:,1], k=faces[:,2],
            color=color, opacity=opacity, name=name,
            showscale=False,
            lighting=dict(ambient=0.6, diffuse=0.8, specular=0.2),
        )
    except Exception:
        return None


def add_skeleton(fig, coords, elems, dx=0., dy=0., dz=0., row=1, col=1):
    import plotly.graph_objects as go
    ELEM_COLOR = {"C":"#888888","H":"#cccccc","N":"#4499ff",
                  "O":"#ff4444","Zn":"#bb44ff"}
    ELEM_SIZE  = {"C":4,"H":2,"N":5,"O":5,"Zn":8}
    shifted = coords + np.array([dx, dy, dz])
    fig.add_trace(go.Scatter3d(
        x=shifted[:,0], y=shifted[:,1], z=shifted[:,2],
        mode='markers',
        marker=dict(size=[ELEM_SIZE.get(e,4) for e in elems],
                    color=[ELEM_COLOR.get(e,'gray') for e in elems],
                    opacity=0.85),
        showlegend=False,
    ), row=row, col=col)
    for i in range(len(shifted)):
        for j in range(i+1, len(shifted)):
            if np.linalg.norm(shifted[i]-shifted[j]) < 1.8:
                fig.add_trace(go.Scatter3d(
                    x=[shifted[i,0],shifted[j,0]],
                    y=[shifted[i,1],shifted[j,1]],
                    z=[shifted[i,2],shifted[j,2]],
                    mode='lines', line=dict(color='#555555',width=2),
                    showlegend=False,
                ), row=row, col=col)


def visualise_mos(fields_d, fields_a, grids_d, grids_a,
                  coords_d, elems_d, coords_a, elems_a,
                  dx, dy, dz, output_html,
                  S_pi=None, S_pistar=None, V_DET=None):
    """
    Two side-by-side panels each showing both molecules together.
    Panel titles show the overlap integral for that pair.
    Main title shows V_DET.
    """
    import plotly.graph_objects as go
    from plotly.subplots import make_subplots

    x_d, y_d, z_d = grids_d
    x_a, y_a, z_a = grids_a
    x_as = x_a + dx
    y_as = y_a + dy
    z_as = z_a + dz

    s_pi_str     = f"  S = {S_pi:.3e}"     if S_pi     is not None else ""
    s_pistar_str = f"  S = {S_pistar:.3e}" if S_pistar  is not None else ""
    vdet_str     = f"V_DET = {V_DET:.3e}"  if V_DET    is not None else ""

    panels = [
        (fields_d[0], x_d, y_d, z_d,
         fields_a[0], x_as, y_as, z_as,
         f"pi_D | pi_A{s_pi_str}"),
        (fields_d[1], x_d, y_d, z_d,
         fields_a[1], x_as, y_as, z_as,
         f"pi*_D | pi*_A{s_pistar_str}"),
    ]

    fig = make_subplots(
        rows=1, cols=2,
        specs=[[{"type":"scene"},{"type":"scene"}]],
        horizontal_spacing=0.03,
    )

    for col, (fd, xd, yd, zd, fa, xa, ya, za, title) in enumerate(panels, start=1):
        # ZnP MO: blue (+) / cyan (-)
        for iso, clr, nm in [(ISOVAL,'#1a6bcc','ZnP +'),
                              (-ISOVAL,'#55ccff','ZnP -')]:
            t = make_isosurface(xd, yd, zd, fd, iso, clr, 0.6, nm)
            if t: fig.add_trace(t, row=1, col=col)
        # PMI MO: red (+) / orange (-)
        for iso, clr, nm in [(ISOVAL,'#cc2200','PMI +'),
                              (-ISOVAL,'#ff8800','PMI -')]:
            t = make_isosurface(xa, ya, za, fa, iso, clr, 0.6, nm)
            if t: fig.add_trace(t, row=1, col=col)
        # Both skeletons
        add_skeleton(fig, coords_d, elems_d, row=1, col=col)
        add_skeleton(fig, coords_a, elems_a, dx=dx, dy=dy, dz=dz, row=1, col=col)

    scene_style = dict(
        bgcolor='#111122',
        xaxis=dict(showgrid=False, zeroline=False, showticklabels=False, title=''),
        yaxis=dict(showgrid=False, zeroline=False, showticklabels=False, title=''),
        zaxis=dict(showgrid=False, zeroline=False, showticklabels=False, title=''),
    )
    fig.update_layout(scene=scene_style, scene2=scene_style)

    annotations = [
        dict(text=panels[0][8], x=0.25, y=1.02, xref='paper', yref='paper',
             showarrow=False, xanchor='center',
             font=dict(size=12, color='white', family='monospace')),
        dict(text=panels[1][8], x=0.75, y=1.02, xref='paper', yref='paper',
             showarrow=False, xanchor='center',
             font=dict(size=12, color='white', family='monospace')),
    ]

    fig.update_layout(
        annotations=annotations,
        title=dict(
            text=(f"ZnP/PMI Mode A (cube) — {EDGE_TO_EDGE_DIST} Å anchor-to-anchor  |  "
                  f"Blue=ZnP  Red=PMI  isoval=±{ISOVAL}  |  {vdet_str}"),
            font=dict(size=12, color='white', family='monospace'),
            x=0.5, xanchor='center',
        ),
        height=700, width=1300,
        paper_bgcolor='#111122',
        font=dict(color='white', family='monospace'),
    )

    fig.write_html(output_html)
    print(f"  MO visualisation saved to: {output_html}")

    import subprocess
    gcs_dest = f"gs://orca_bucket/angel/{output_html.split('/')[-1]}"
    result = subprocess.run(
        ["gsutil", "-m", "cp", "-r", output_html, gcs_dest],
        capture_output=True, text=True
    )
    if result.returncode == 0:
        print(f"  Uploaded to: {gcs_dest}")
    else:
        print(f"  WARNING: GCS upload failed — {result.stderr.strip()}")


# ------------------------------------------------------------
# MAIN
# ------------------------------------------------------------

def main():
    print("=" * 60)
    print(f"ZnP/PMI DET — Mode A cube, {EDGE_TO_EDGE_DIST} Å anchor-to-anchor")
    print("=" * 60)

    print("\nReading cube files...")
    origin_d, axes_d, npts_d, field_pi_D     = read_cube(CUBE_PI_D)
    _,        _,      _,      field_pistar_D  = read_cube(CUBE_PISTAR_D)
    origin_a, axes_a, npts_a, field_pi_A     = read_cube(CUBE_PI_A)
    _,        _,      _,      field_pistar_A  = read_cube(CUBE_PISTAR_A)
    print(f"  ZnP grid: {npts_d[0]}x{npts_d[1]}x{npts_d[2]}")
    print(f"  PMI grid: {npts_a[0]}x{npts_a[1]}x{npts_a[2]}")

    x_d, y_d, z_d = get_grid_coords(origin_d, axes_d, npts_d)
    x_a, y_a, z_a = get_grid_coords(origin_a, axes_a, npts_a)
    dV_d = voxel_volume(axes_d)
    dV_a = voxel_volume(axes_a)

    print("\nReading atom coords from cube headers...")
    coords_d, elems_d = get_mol_coords_from_cube(CUBE_PI_D)
    coords_a, elems_a = get_mol_coords_from_cube(CUBE_PI_A)
    print(f"  ZnP anchor: ({ZNP_ANCHOR[0]:.3f}, {ZNP_ANCHOR[1]:.3f}, {ZNP_ANCHOR[2]:.3f}) Å")
    print(f"  PMI anchor: ({PMI_ANCHOR[0]:.3f}, {PMI_ANCHOR[1]:.3f}, {PMI_ANCHOR[2]:.3f}) Å")

    print("\nNormalisation check (should be ~1.0):")
    norm_pi_D     = normalisation(field_pi_D,     dV_d)
    norm_pistar_D = normalisation(field_pistar_D,  dV_d)
    norm_pi_A     = normalisation(field_pi_A,     dV_a)
    norm_pistar_A = normalisation(field_pistar_A,  dV_a)
    for label, n in [("pi_D",norm_pi_D),("pi*_D",norm_pistar_D),
                     ("pi_A",norm_pi_A),("pi*_A",norm_pistar_A)]:
        print(f"  ∫|{label}|² dV = {n:.4f}")

    c_pi_D     = 1.0 / np.sqrt(norm_pi_D)     if norm_pi_D     > 0 else 1.0
    c_pistar_D = 1.0 / np.sqrt(norm_pistar_D)  if norm_pistar_D > 0 else 1.0
    c_pi_A     = 1.0 / np.sqrt(norm_pi_A)     if norm_pi_A     > 0 else 1.0
    c_pistar_A = 1.0 / np.sqrt(norm_pistar_A)  if norm_pistar_A > 0 else 1.0

    print(f"\nShifting PMI grid to {EDGE_TO_EDGE_DIST:.1f} Å from ZnP...")
    print("  Interpolating pi_A...")
    field_pi_A_on_d, dx, dy, dz = shift_and_interpolate(
        field_pi_A, x_a, y_a, z_a, x_d, y_d, z_d, EDGE_TO_EDGE_DIST)
    print(f"    Translation: dX={dx:.4f}  dY={dy:.4f}  dZ={dz:.4f} Å")
    print("  Interpolating pi*_A...")
    field_pistar_A_on_d, _, _, _ = shift_and_interpolate(
        field_pistar_A, x_a, y_a, z_a, x_d, y_d, z_d, EDGE_TO_EDGE_DIST)

    print("\nComputing overlap integrals...")
    S_pi_raw     = compute_overlap(field_pi_D,    field_pi_A_on_d,     dV_d)
    S_pistar_raw = compute_overlap(field_pistar_D, field_pistar_A_on_d, dV_d)
    S_pi_corr     = S_pi_raw     * c_pi_D    * c_pi_A
    S_pistar_corr = S_pistar_raw * c_pistar_D * c_pistar_A
    V_DET_raw   = S_pi_raw     * S_pistar_raw
    V_DET_corr  = S_pi_corr    * S_pistar_corr

    print("\nGenerating MO visualisation...")
    visualise_mos(
        fields_d=[field_pi_D, field_pistar_D],
        fields_a=[field_pi_A, field_pistar_A],
        grids_d=(x_d, y_d, z_d),
        grids_a=(x_a, y_a, z_a),
        coords_d=coords_d, elems_d=elems_d,
        coords_a=coords_a, elems_a=elems_a,
        dx=dx, dy=dy, dz=dz,
        output_html=OUTPUT_HTML,
        S_pi=S_pi_corr, S_pistar=S_pistar_corr, V_DET=V_DET_corr,
    )

    print("\n" + "=" * 60)
    print("RESULTS — ZnP/PMI DET at x=0, edge-to-edge 2.0 Å")
    print("=" * 60)
    print(f"\n  Raw (no normalisation correction):")
    print(f"    S(pi_D,  pi_A)   = {S_pi_raw:.6e}")
    print(f"    S(pi*_D, pi*_A)  = {S_pistar_raw:.6e}")
    print(f"    V_DET            = {V_DET_raw:.6e}")
    print(f"\n  Corrected (c² normalisation):")
    print(f"    S(pi_D,  pi_A)   = {S_pi_corr:.6e}")
    print(f"    S(pi*_D, pi*_A)  = {S_pistar_corr:.6e}")
    print(f"    V_DET            = {V_DET_corr:.6e}")
    print(f"\n  Correction factors:")
    print(f"    c(pi_D)   = {c_pi_D:.4f}   c(pi*_D)  = {c_pistar_D:.4f}")
    print(f"    c(pi_A)   = {c_pi_A:.4f}   c(pi*_A)  = {c_pistar_A:.4f}")
    print(f"\n  Note: V_DET = kappa x S_pi x S_pi*")
    print(f"        kappa for ZnP/PMI not yet determined")
    print("=" * 60)


if __name__ == "__main__":
    main()
