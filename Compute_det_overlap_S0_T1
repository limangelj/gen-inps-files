#!/usr/bin/env python3
"""
Compute Dexter Energy Transfer (DET) orbital overlaps for naphthalene dimer.

Physically rigorous approach — different MOs for donor and acceptor.
Donor:    T1 opt geometry, triplet SP -> SOMO-1 = pi_D,  SOMO = pi*_D
Acceptor: S0 opt geometry, singlet SP -> HOMO   = pi_A,  LUMO = pi*_A

This approach is correct for heterodimer systems (e.g. ZnP/PMI).
"""

import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D
from pyscf import gto
from pyscf.tools import molden
import subprocess

# ------------------------------------------------------------
# FILE PATHS
# ------------------------------------------------------------
BASE_DIR        = "/nfs/outputs/naphthalene"
GCS_BUCKET      = "gs://orca_bucket/angel/"
DONOR_XYZ       = f"{BASE_DIR}/naphthalene_b3lyp_6311ppgss_t1_opt.xyz"
ACCEPTOR_XYZ    = f"{BASE_DIR}/naphthalene_b3lyp_6311ppgss_s0_opt.xyz"
DONOR_MOLDEN    = f"{BASE_DIR}/naphthalene_camb3lyp_6311ppgss_t1_sp_t1geom.molden.input"
ACCEPTOR_MOLDEN = f"{BASE_DIR}/naphthalene_camb3lyp_6311ppgss_s0_sp.molden.input"

# Cube files for MO visualisation (generated by orca_plot)
CUBE_PI_D     = f"{BASE_DIR}/naphthalene_camb3lyp_6311ppgss_t1_sp_t1geom.mo33a.cube"
CUBE_PISTAR_D = f"{BASE_DIR}/naphthalene_camb3lyp_6311ppgss_t1_sp_t1geom.mo34a.cube"
CUBE_PI_A     = f"{BASE_DIR}/naphthalene_camb3lyp_6311ppgss_s0_sp.mo33a.cube"
CUBE_PISTAR_A = f"{BASE_DIR}/naphthalene_camb3lyp_6311ppgss_s0_sp.mo34a.cube"

# ------------------------------------------------------------
# ORBITAL INDICES (0-based)
# Donor (triplet):
#   SOMO-1 = alpha orbital 33 = pi_D
#   SOMO   = alpha orbital 34 = pi*_D
# Acceptor (singlet):
#   HOMO   = orbital 33 = pi_A
#   LUMO   = orbital 34 = pi*_A
# ------------------------------------------------------------
DONOR_PI_IDX      = 33
DONOR_PISTAR_IDX  = 34
ACCEPT_PI_IDX     = 33
ACCEPT_PISTAR_IDX = 34

# ------------------------------------------------------------
# SCAN PARAMETERS
# ------------------------------------------------------------
STACK_DISTANCE = 3.5
X_START        = 0.0
X_END          = 8.0
N_POINTS       = 50
BASIS          = "6-311++G**"
KAPPA          = 24.0  # eV, Bai et al. 2020

# Orbital verification — expected energies from ORCA output (Hartree)
EXPECTED_PI_D_EH     = -0.296193  # SOMO-1 from T1 SP
EXPECTED_PISTAR_D_EH = -0.172635  # SOMO   from T1 SP
EXPECTED_PI_A_EH     = -0.273588  # HOMO   from S0 SP
EXPECTED_PISTAR_A_EH = -0.008225  # LUMO   from S0 SP
TOLERANCE            =  0.001

# ------------------------------------------------------------
# OUTPUT FILE NAMES
# ------------------------------------------------------------
OUTPUT_CSV     = f"{BASE_DIR}/det_overlaps_rigorous.csv"
OUTPUT_PNG     = f"{BASE_DIR}/det_overlaps_rigorous.png"
OUTPUT_MO_PNG  = f"{BASE_DIR}/mo_visualisation_rigorous.png"
OUTPUT_MO_HTML = f"{BASE_DIR}/mo_visualisation_rigorous.html"
DIMER_PNG_STEM = f"{BASE_DIR}/dimer_geometry_rigorous_x"

# ------------------------------------------------------------
# HELPER FUNCTIONS
# ------------------------------------------------------------

def read_xyz(filepath):
    atoms = []
    with open(filepath) as f:
        lines = f.readlines()
    for line in lines[2:]:
        parts = line.split()
        if len(parts) == 4:
            elem = parts[0]
            x, y, z = float(parts[1]), float(parts[2]), float(parts[3])
            atoms.append((elem, x, y, z))
    return atoms


def centre_atoms(atoms):
    xs = [x for _, x, _, _ in atoms]
    ys = [y for _, _, y, _ in atoms]
    cx = sum(xs) / len(xs)
    cy = sum(ys) / len(ys)
    return [(e, x-cx, y-cy, z) for e, x, y, z in atoms]


def shift_atoms(atoms, dx=0.0, dy=0.0, dz=0.0):
    return [(e, x+dx, y+dy, z+dz) for e, x, y, z in atoms]


def atoms_to_pyscf_str(atoms):
    lines = [f"{e} {x:.8f} {y:.8f} {z:.8f}" for e, x, y, z in atoms]
    return "; ".join(lines)


def build_mol(atoms, basis, charge=0, spin=0):
    mol = gto.Mole()
    mol.atom = atoms_to_pyscf_str(atoms)
    mol.basis = basis
    mol.charge = charge
    mol.spin = spin
    mol.verbose = 0
    mol.build()
    return mol


def get_mo_coeffs_from_molden(molden_file, mol):
    result    = molden.load(molden_file)
    mo_energy = result[1]
    mo_coeff  = result[2]
    mo_occ    = result[3]
    mo_coeff_arr = np.array(mo_coeff)
    is_uhf = mo_coeff_arr.ndim == 3
    if is_uhf:
        coeffs   = mo_coeff_arr[0]
        energies = np.array(mo_energy)[0]
        occs     = np.array(mo_occ)[0]
    else:
        coeffs   = mo_coeff_arr
        energies = np.array(mo_energy)
        occs     = np.array(mo_occ)
    return coeffs, occs, energies, is_uhf


def read_cube(cube_file):
    """
    Read an ORCA cube file.
    Returns x, y, z grid arrays (Angstrom) and field values.
    Note: ORCA MO cube files use negative natoms — handled with abs().
    """
    with open(cube_file) as f:
        lines = f.readlines()
    # ORCA uses negative natoms for MO cube files
    natoms = abs(int(lines[2].split()[0]))
    origin = np.array([float(v) for v in lines[2].split()[1:4]]) * 0.529177
    nx = int(lines[3].split()[0])
    dx = float(lines[3].split()[1]) * 0.529177
    ny = int(lines[4].split()[0])
    dy = float(lines[4].split()[2]) * 0.529177
    nz = int(lines[5].split()[0])
    dz = float(lines[5].split()[3]) * 0.529177
    # MO cube files have an extra line after atom coords
    # containing MO index info — skip natoms+1 lines after header
    data_start = 6 + natoms + 1
    data_lines = lines[data_start:]
    values = []
    for line in data_lines:
        values.extend([float(v) for v in line.split()])
    field = np.array(values[:nx*ny*nz]).reshape(nx, ny, nz)
    x = origin[0] + np.arange(nx) * dx
    y = origin[1] + np.arange(ny) * dy
    z = origin[2] + np.arange(nz) * dz
    return x, y, z, field


def visualize_dimer(donor_atoms, acceptor_atoms, x_displacement, save_path):
    fig = plt.figure(figsize=(10, 8))
    ax = fig.add_subplot(111, projection="3d")
    for elem, x, y, z in donor_atoms:
        size = 200 if elem == "C" else 80
        ax.scatter(x, y, z, c="blue", s=size, alpha=0.8,
                   edgecolors="darkblue", linewidths=0.5)
    for elem, x, y, z in acceptor_atoms:
        size = 200 if elem == "C" else 80
        ax.scatter(x, y, z, c="red", s=size, alpha=0.8,
                   edgecolors="darkred", linewidths=0.5)
    donor_carbons    = [(x, y, z) for e, x, y, z in donor_atoms if e == "C"]
    acceptor_carbons = [(x, y, z) for e, x, y, z in acceptor_atoms if e == "C"]
    for carbons, color in [(donor_carbons, "blue"), (acceptor_carbons, "red")]:
        for i, (x1, y1, z1) in enumerate(carbons):
            for x2, y2, z2 in carbons[i+1:]:
                dist = np.sqrt((x2-x1)**2 + (y2-y1)**2 + (z2-z1)**2)
                if dist < 1.6:
                    ax.plot([x1, x2], [y1, y2], [z1, z2],
                            color=color, linewidth=1.5, alpha=0.7)
    ax.set_xlabel("X (Å)")
    ax.set_ylabel("Y (Å)")
    ax.set_zlabel("Z (Å)")
    ax.set_title(f"Stacked Naphthalenes (T1-S0) — x = {x_displacement:.2f} Å\n"
                 f"Blue = Donor (T1), Red = Acceptor (S0), Z-stack = {STACK_DISTANCE} Å")
    from matplotlib.lines import Line2D
    legend_elements = [
        Line2D([0], [0], marker="o", color="w", markerfacecolor="blue",
               markersize=10, label="Donor (T1, fixed)"),
        Line2D([0], [0], marker="o", color="w", markerfacecolor="red",
               markersize=10, label=f"Acceptor (S0, x={x_displacement:.1f} Å)"),
    ]
    ax.legend(handles=legend_elements)
    plt.tight_layout()
    plt.savefig(save_path, dpi=150)
    print(f"  Dimer geometry saved to: {save_path}")
    plt.close()


def compute_mo_overlap(mol_d, mo_d, mol_a, mo_a):
    donor_atoms    = [(mol_d.atom_symbol(i), *mol_d.atom_coord(i))
                      for i in range(mol_d.natm)]
    acceptor_atoms = [(mol_a.atom_symbol(i), *mol_a.atom_coord(i))
                      for i in range(mol_a.natm)]
    mol_dimer = gto.Mole()
    mol_dimer.atom = donor_atoms + acceptor_atoms
    mol_dimer.basis = BASIS
    mol_dimer.verbose = 0
    mol_dimer.unit = "Bohr"
    mol_dimer.build()
    S_ao  = mol_dimer.intor("int1e_ovlp")
    nao_d = mol_d.nao
    S_da  = S_ao[:nao_d, nao_d:]
    S_mo  = mo_d @ S_da @ mo_a
    return S_mo


def upload_to_gcs(local_dir, gcs_bucket):
    print(f"\nUploading results to {gcs_bucket}...")
    for pattern in ["*.png", "*.csv", "*.html"]:
        cmd = ["gsutil", "-m", "cp", f"{local_dir}/{pattern}", gcs_bucket]
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode == 0:
            print(f"  Uploaded {pattern} successfully")
        else:
            print(f"  Warning: upload of {pattern} failed")
            print(f"  {result.stderr.strip()}")


def visualize_mos(save_path):
    """
    Visualise the four key MOs as 3D isosurfaces using Plotly.
    Reads pre-generated cube files from orca_plot — same data as Avogadro.
    Saves interactive HTML file.
    Positive lobe = red, negative lobe = blue.
    """
    import plotly.graph_objects as go
    from plotly.subplots import make_subplots
    from skimage.measure import marching_cubes

    def make_mesh(x, y, z, field, isoval, color, opacity):
        try:
            verts, faces, _, _ = marching_cubes(
                field, level=isoval,
                spacing=(x[1]-x[0], y[1]-y[0], z[1]-z[0])
            )
            verts[:, 0] += x[0]
            verts[:, 1] += y[0]
            verts[:, 2] += z[0]
            return go.Mesh3d(
                x=verts[:, 0], y=verts[:, 1], z=verts[:, 2],
                i=faces[:, 0], j=faces[:, 1], k=faces[:, 2],
                color=color, opacity=opacity, showscale=False,
                lighting=dict(ambient=0.5, diffuse=0.8,
                              specular=0.2, roughness=0.5),
            )
        except Exception:
            return None

    def add_skeleton_from_cube(fig, cube_file, row, col):
        ELEM_COLOR = {"C": "gray", "H": "white", "N": "blue",
                      "O": "red",  "Zn": "purple"}
        ELEM_SIZE  = {"C": 8, "H": 4, "N": 8, "O": 8, "Zn": 12}
        ELEM_NUM   = {6: "C", 1: "H", 7: "N", 8: "O", 30: "Zn"}
        with open(cube_file) as f:
            lines = f.readlines()
        natoms = abs(int(lines[2].split()[0]))
        coords, symbols = [], []
        # Atom lines start at line 6, read exactly natoms lines
        for line in lines[6:6+natoms]:
            parts = line.split()
            if len(parts) < 5:
                continue  # skip MO index line if encountered
            elem = ELEM_NUM.get(int(parts[0]), "C")
            x = float(parts[2]) * 0.529177
            y = float(parts[3]) * 0.529177
            z = float(parts[4]) * 0.529177
            coords.append([x, y, z])
            symbols.append(elem)
        coords = np.array(coords)
        fig.add_trace(
            go.Scatter3d(
                x=coords[:, 0], y=coords[:, 1], z=coords[:, 2],
                mode="markers",
                marker=dict(
                    size=[ELEM_SIZE.get(s, 6) for s in symbols],
                    color=[ELEM_COLOR.get(s, "gray") for s in symbols],
                    opacity=1.0, line=dict(width=1, color="black")
                ),
                showlegend=False, name="atoms",
            ), row=row, col=col
        )
        for i in range(len(coords)):
            for j in range(i+1, len(coords)):
                dist = np.linalg.norm(coords[i] - coords[j])
                if dist < 1.7:
                    fig.add_trace(
                        go.Scatter3d(
                            x=[coords[i, 0], coords[j, 0]],
                            y=[coords[i, 1], coords[j, 1]],
                            z=[coords[i, 2], coords[j, 2]],
                            mode="lines",
                            line=dict(color="black", width=4),
                            showlegend=False, name="bond",
                        ), row=row, col=col
                    )

    cube_files = [
        (CUBE_PI_D,     r"π_D (SOMO-1, Donor T1)"),
        (CUBE_PISTAR_D, r"π*_D (SOMO, Donor T1)"),
        (CUBE_PI_A,     r"π_A (HOMO, Acceptor S0)"),
        (CUBE_PISTAR_A, r"π*_A (LUMO, Acceptor S0)"),
    ]

    fig = make_subplots(
        rows=2, cols=2,
        subplot_titles=[c[1] for c in cube_files],
        specs=[[{"type": "scene"}, {"type": "scene"}],
               [{"type": "scene"}, {"type": "scene"}]],
        horizontal_spacing=0.05,
        vertical_spacing=0.1
    )

    isoval = 0.03

    for (row, col), (cube_file, label) in zip(
            [(1,1),(1,2),(2,1),(2,2)], cube_files):
        print(f"  Reading cube file for {label}...")
        x, y, z, field = read_cube(cube_file)

        pos = make_mesh(x, y, z,  field, isoval, "red",  0.5)
        if pos: fig.add_trace(pos, row=row, col=col)

        neg = make_mesh(x, y, z, -field, isoval, "blue", 0.5)
        if neg: fig.add_trace(neg, row=row, col=col)

        add_skeleton_from_cube(fig, cube_file, row, col)

    fig.update_layout(
        title=f"MO Verification (T1-S0) — Cube File Isosurfaces "
              f"(isovalue = ±{isoval})",
        height=900, width=1100,
    )

    html_path = save_path.replace(".png", ".html")
    fig.write_html(html_path)
    print(f"  3D MO visualisation saved to: {html_path}")

    try:
        fig.write_image(save_path)
        print(f"  Static MO visualisation saved to: {save_path}")
    except Exception:
        print(f"  Note: install kaleido for PNG export: pip install kaleido")


# ------------------------------------------------------------
# MAIN
# ------------------------------------------------------------

def main():
    print("Mode: RIGOROUS (triplet MOs for D, singlet MOs for A)")
    print("Reading and centring geometries...")
    donor_atoms_base    = centre_atoms(read_xyz(DONOR_XYZ))
    acceptor_atoms_base = centre_atoms(read_xyz(ACCEPTOR_XYZ))

    d_cx = sum(x for _, x, _, _ in donor_atoms_base) / len(donor_atoms_base)
    d_cy = sum(y for _, _, y, _ in donor_atoms_base) / len(donor_atoms_base)
    a_cx = sum(x for _, x, _, _ in acceptor_atoms_base) / len(acceptor_atoms_base)
    a_cy = sum(y for _, _, y, _ in acceptor_atoms_base) / len(acceptor_atoms_base)
    print(f"  Donor centroid    (x, y): ({d_cx:.6f}, {d_cy:.6f})")
    print(f"  Acceptor centroid (x, y): ({a_cx:.6f}, {a_cy:.6f})")

    print("\nBuilding donor molecule and reading MOs...")
    mol_donor = build_mol(donor_atoms_base, BASIS, charge=0, spin=2)

    mo_coeffs_d, mo_occ_d, mo_energy_d, is_uhf = \
        get_mo_coeffs_from_molden(DONOR_MOLDEN, mol_donor)

    if mo_coeffs_d.ndim == 1:
        nao = mol_donor.nao
        mo_coeffs_d = mo_coeffs_d.reshape(nao, mo_coeffs_d.shape[0] // nao)

    pi_D     = mo_coeffs_d[:, DONOR_PI_IDX]
    pistar_D = mo_coeffs_d[:, DONOR_PISTAR_IDX]

    print(f"  Donor MO coeffs shape: {mo_coeffs_d.shape}")
    print(f"  pi_D   (SOMO-1) energy: {mo_energy_d[DONOR_PI_IDX]:.6f} Eh "
          f"({mo_energy_d[DONOR_PI_IDX]*27.211:.4f} eV)")
    print(f"  pi*_D  (SOMO)   energy: {mo_energy_d[DONOR_PISTAR_IDX]:.6f} Eh "
          f"({mo_energy_d[DONOR_PISTAR_IDX]*27.211:.4f} eV)")

    print("\nVerifying donor orbital indices...")
    if abs(mo_energy_d[DONOR_PI_IDX] - EXPECTED_PI_D_EH) < TOLERANCE:
        print(f"  pi_D   index {DONOR_PI_IDX} confirmed ✓  "
              f"(E = {mo_energy_d[DONOR_PI_IDX]:.6f} Eh)")
    else:
        print(f"  WARNING: pi_D energy mismatch — got "
              f"{mo_energy_d[DONOR_PI_IDX]:.6f}, expected {EXPECTED_PI_D_EH:.6f} Eh")

    if abs(mo_energy_d[DONOR_PISTAR_IDX] - EXPECTED_PISTAR_D_EH) < TOLERANCE:
        print(f"  pi*_D  index {DONOR_PISTAR_IDX} confirmed ✓  "
              f"(E = {mo_energy_d[DONOR_PISTAR_IDX]:.6f} Eh)")
    else:
        print(f"  WARNING: pi*_D energy mismatch — got "
              f"{mo_energy_d[DONOR_PISTAR_IDX]:.6f}, expected {EXPECTED_PISTAR_D_EH:.6f} Eh")

    print("\nBuilding acceptor molecule and verifying MOs...")
    acceptor_atoms_vis = shift_atoms(acceptor_atoms_base,
                                     dx=0.0, dy=0.0, dz=STACK_DISTANCE)
    mol_acceptor_vis = build_mol(acceptor_atoms_vis, BASIS, charge=0, spin=0)

    mo_coeffs_a_vis, _, mo_energy_a_vis, _ = \
        get_mo_coeffs_from_molden(ACCEPTOR_MOLDEN, mol_acceptor_vis)

    if mo_coeffs_a_vis.ndim == 1:
        nao = mol_acceptor_vis.nao
        mo_coeffs_a_vis = mo_coeffs_a_vis.reshape(
            nao, mo_coeffs_a_vis.shape[0] // nao)

    print(f"  Acceptor pi_A  (HOMO) energy: "
          f"{mo_energy_a_vis[ACCEPT_PI_IDX]:.6f} Eh "
          f"({mo_energy_a_vis[ACCEPT_PI_IDX]*27.211:.4f} eV)")
    print(f"  Acceptor pi*_A (LUMO) energy: "
          f"{mo_energy_a_vis[ACCEPT_PISTAR_IDX]:.6f} Eh "
          f"({mo_energy_a_vis[ACCEPT_PISTAR_IDX]*27.211:.4f} eV)")

    print("\nVerifying acceptor orbital indices...")
    if abs(mo_energy_a_vis[ACCEPT_PI_IDX] - EXPECTED_PI_A_EH) < TOLERANCE:
        print(f"  pi_A   index {ACCEPT_PI_IDX} confirmed ✓  "
              f"(E = {mo_energy_a_vis[ACCEPT_PI_IDX]:.6f} Eh)")
    else:
        print(f"  WARNING: pi_A energy mismatch — got "
              f"{mo_energy_a_vis[ACCEPT_PI_IDX]:.6f}, expected {EXPECTED_PI_A_EH:.6f} Eh")

    if abs(mo_energy_a_vis[ACCEPT_PISTAR_IDX] - EXPECTED_PISTAR_A_EH) < TOLERANCE:
        print(f"  pi*_A  index {ACCEPT_PISTAR_IDX} confirmed ✓  "
              f"(E = {mo_energy_a_vis[ACCEPT_PISTAR_IDX]:.6f} Eh)")
    else:
        print(f"  WARNING: pi*_A energy mismatch — got "
              f"{mo_energy_a_vis[ACCEPT_PISTAR_IDX]:.6f}, expected {EXPECTED_PISTAR_A_EH:.6f} Eh")

    print("\nVisualising dimer geometry...")
    for dx_vis in [0.0, 1.5, 4.0]:
        acceptor_vis = shift_atoms(acceptor_atoms_base,
                                   dx=dx_vis, dy=0.0, dz=STACK_DISTANCE)
        visualize_dimer(donor_atoms_base, acceptor_vis, dx_vis,
                        save_path=f"{DIMER_PNG_STEM}{dx_vis:.1f}.png")

    print("\nVisualising MOs from cube files...")
    visualize_mos(save_path=OUTPUT_MO_PNG)

    x_values  = np.linspace(X_START, X_END, N_POINTS)
    S_pi      = np.zeros(N_POINTS)
    S_pistar  = np.zeros(N_POINTS)
    V_DET     = np.zeros(N_POINTS)
    V_DET_eV  = np.zeros(N_POINTS)

    print(f"\nScanning acceptor along x-axis ({N_POINTS} points)...")
    for i, dx in enumerate(x_values):
        print(f"  x = {dx:.2f} Å  ({i+1}/{N_POINTS})", end="\r")

        acceptor_atoms = shift_atoms(acceptor_atoms_base,
                                     dx=dx, dy=0.0, dz=STACK_DISTANCE)
        mol_acceptor = build_mol(acceptor_atoms, BASIS, charge=0, spin=0)

        mo_coeffs_a, _, _, _ = \
            get_mo_coeffs_from_molden(ACCEPTOR_MOLDEN, mol_acceptor)

        if mo_coeffs_a.ndim == 1:
            nao = mol_acceptor.nao
            mo_coeffs_a = mo_coeffs_a.reshape(nao, mo_coeffs_a.shape[0] // nao)

        pi_A     = mo_coeffs_a[:, ACCEPT_PI_IDX]
        pistar_A = mo_coeffs_a[:, ACCEPT_PISTAR_IDX]

        S_pi[i]     = compute_mo_overlap(mol_donor, pi_D, mol_acceptor, pi_A)
        S_pistar[i] = compute_mo_overlap(mol_donor, pistar_D, mol_acceptor, pistar_A)
        V_DET[i]    = S_pi[i] * S_pistar[i]
        V_DET_eV[i] = KAPPA * V_DET[i]

    print("\nDone.")

    header = "x_displacement_Ang,S_pi_D_pi_A,S_pistar_D_pistar_A,V_DET_product,V_DET_eV"
    data   = np.column_stack([x_values, S_pi, S_pistar, V_DET, V_DET_eV])
    np.savetxt(OUTPUT_CSV, data, delimiter=",", header=header)
    print(f"Results saved to: {OUTPUT_CSV}")

    fig, axes = plt.subplots(3, 1, figsize=(8, 10), sharex=True)

    axes[0].plot(x_values, S_pi, "b-o", markersize=3)
    axes[0].set_ylabel(r"$S(\pi_D, \pi_A)$")
    axes[0].axhline(0, color="k", linewidth=0.5)
    axes[0].set_title("Stacked Naphthalenes DET Orbital Overlaps (T1-S0)")

    axes[1].plot(x_values, S_pistar, "r-o", markersize=3)
    axes[1].set_ylabel(r"$S(\pi^*_D, \pi^*_A)$")
    axes[1].axhline(0, color="k", linewidth=0.5)

    axes[2].semilogy(x_values, np.abs(V_DET_eV), "g-o", markersize=3)
    axes[2].set_ylabel(r"$|V_{DET}|$ (eV)")
    axes[2].set_xlabel("x displacement (Å)")
    axes[2].set_title(r"$|V_{DET}| = \kappa \times |S \cdot S^*|$, "
                      r"$\kappa$ = 24 eV (log scale)")

    plt.tight_layout()
    plt.savefig(OUTPUT_PNG, dpi=150)
    print(f"Plot saved to: {OUTPUT_PNG}")
    plt.show()

