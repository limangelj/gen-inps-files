RUN_TEMPLATE = """\
#!/bin/bash
# Stage 1: geometry optimization
s0_opt_jid=$(qorca -i ./{s0_opt_file} -c {cores} -m 2500)
t1_opt_jid=$(qorca -i ./{t1_opt_file} -c {cores} -m 2500)
# Stage 2: freq + TDDFT in parallel
s0_freq_jid=$(qorca -i ./{s0_freq_file} -c {cores} -m 2500 -n 1 -j ${{s0_opt_jid}})
t1_freq_jid=$(qorca -i ./{t1_freq_file} -c {cores} -m 2500 -n 1 -j ${{t1_opt_jid}})
cam_jid=$(qorca -i ./{cam_tddft_file} -c {cores} -m 2500 -n 1 -j ${{s0_opt_jid}})
wb9_jid=$(qorca -i ./{wb9_tddft_file} -c {cores} -m 2500 -n 1 -j ${{s0_opt_jid}})
sos_jid=$(qorca -i ./{sos_tddft_file} -c {cores} -m 2500 -n 1 -j ${{s0_opt_jid}})
m06_jid=$(qorca -i ./{m06_tddft_file} -c {cores} -m 2500 -n 1 -j ${{s0_opt_jid}})
# Stage 3: all CCSD methods in parallel
dlpno_jid=$(qorca -i ./{dlpno_file} -c {cores} -m 8000 -d 6000 -n 1 -p highres -j ${{s0_opt_jid}}:${{s0_freq_jid}})
s0_ccsd_jid=$(qorca -i ./{ccsd_s0geom_file} -c 8 -m 9500 -d 2000 -n 1 -p highres -j ${{s0_opt_jid}})
t1_ccsd_jid=$(qorca -i ./{ccsd_t1geom_file} -c 8 -m 9500 -d 2000 -n 1 -p highres -j ${{t1_opt_jid}}:${{t1_freq_jid}})
"""

def parse_args():
    parser = argparse.ArgumentParser(
        description="Generate ORCA input files and submission scripts",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter
    )
    parser.add_argument("name", help="Base name for output files")
    parser.add_argument("xyz", help="Input .xyz file")
    parser.add_argument("charge", type=int, help="Molecule net charge")
    parser.add_argument("--mult", type=int, default=1,
                        help="Spin multiplicity")
    parser.add_argument("-s", "--solvent", default="water",
                        help="Solvent name for CPCM (e.g. water, acetonitrile, dichloromethane)")
    parser.add_argument("-c", "--cores", type=int, default=16,
                        help="Number of CPU cores requested from the scheduler (qorca -c)")
    return parser.parse_args()

def check_xyz(xyz_path: Path):
    if not xyz_path.exists():
        print(f"Error: {xyz_path} not found.")
        sys.exit(1)
    if xyz_path.suffix != ".xyz":
        print("Error: input file must have .xyz extension.")
        sys.exit(1)

def write_file(path: Path, content: str, executable: bool = False):
    path.write_text(content)
    if executable:
        os.chmod(path, 0o755)
    print(f"  Written: {path}")

def main():
    args = parse_args()
    xyz_path = Path(args.xyz)
    check_xyz(xyz_path)

    stem = args.name
    cores = args.cores

    # --- File paths ---
    s0_opt_stem = f"{stem}_{args.solvent}_m062x_def2-tzvp_s0_opt"
    t1_opt_stem = f"{stem}_{args.solvent}_m062x_def2-tzvp_t1_opt"

    s0_opt_file      = Path(s0_opt_stem + ".inp")
    t1_opt_file      = Path(t1_opt_stem + ".inp")
    s0_opt_xyz       = Path(s0_opt_stem + ".xyz")
    t1_opt_xyz       = Path(t1_opt_stem + ".xyz")

    s0_freq_file     = Path(f"{stem}_{args.solvent}_m062x_def2-tzvp_s0_freq.inp")
    t1_freq_file     = Path(f"{stem}_{args.solvent}_m062x_def2-tzvp_t1_freq.inp")
    cam_tddft_file   = Path(f"{stem}_{args.solvent}_cam-b3lyp_def2-tzvp_tddft.inp")
    wb9_tddft_file   = Path(f"{stem}_{args.solvent}_wb97x-d3_def2-tzvp_tddft.inp")
    sos_tddft_file   = Path(f"{stem}_{args.solvent}_sos_wb88pp86_def2-tzvp_tddft.inp")
    m06_tddft_file   = Path(f"{stem}_{args.solvent}_m062x_def2-tzvp_tddft.inp")
    dlpno_file       = Path(f"{stem}_{args.solvent}_dlpno_steom_ccsd.inp")
    ccsd_s0geom_file = Path(f"{stem}_{args.solvent}_dlpno_ccsdt_s0geom.inp")
    ccsd_t1geom_file = Path(f"{stem}_{args.solvent}_dlpno_ccsdt_t1geom.inp")
    run_file         = Path(f"run_{stem}_{args.solvent}.sh")
    # --- Shared format kwargs ---
    base_kwargs = dict(
        charge=args.charge,
        mult=args.mult,
        solvent=args.solvent,
    )

    # --- Write ORCA inputs ---
    print("Generating ORCA input files...")

    write_file(s0_opt_file, M062X_S0_OPT_TEMPLATE.format(
        xyz=xyz_path.name, **base_kwargs
    ))
    write_file(t1_opt_file, M062X_T1_OPT_TEMPLATE.format(
        xyz=xyz_path.name, **{**base_kwargs, "mult": 3}
    ))
    write_file(s0_freq_file, M062X_S0_FREQ_TEMPLATE.format(
        xyz=s0_opt_xyz, **base_kwargs
    ))
    write_file(t1_freq_file, M062X_T1_FREQ_TEMPLATE.format(
        xyz=t1_opt_xyz, **{**base_kwargs, "mult": 3}
    ))
    write_file(cam_tddft_file, CAM_B3LYP_TDDFT_TEMPLATE.format(
        xyz=s0_opt_xyz, **base_kwargs
    ))
    write_file(wb9_tddft_file, WB97XD3_TDDFT_TEMPLATE.format(
        xyz=s0_opt_xyz, **base_kwargs
    ))
    write_file(sos_tddft_file, SOS_TDDFT_TEMPLATE.format(
        xyz=s0_opt_xyz, cores=cores, **base_kwargs
    ))
    write_file(m06_tddft_file, M062X_TDDFT_TEMPLATE.format(
        xyz=s0_opt_xyz, **base_kwargs
    ))
    write_file(dlpno_file, DLPNO_STEOM_CCSD_TEMPLATE.format(
        xyz=s0_opt_xyz, **base_kwargs
    ))
    write_file(ccsd_s0geom_file, DLPNO_CCSD_S0GEOM_TEMPLATE.format(
        xyz=s0_opt_xyz, **base_kwargs
    ))
    write_file(ccsd_t1geom_file, DLPNO_CCSD_S0GEOM_TEMPLATE.format(
        xyz=t1_opt_xyz, **{**base_kwargs, "mult": 3}
    ))

    # --- Write run script ---
    print("Generating run script...")

    write_file(run_file, RUN_TEMPLATE.format(
        s0_opt_file=s0_opt_file,
        t1_opt_file=t1_opt_file,
        s0_freq_file=s0_freq_file,
        t1_freq_file=t1_freq_file,
        cam_tddft_file=cam_tddft_file,
        wb9_tddft_file=wb9_tddft_file,
        sos_tddft_file=sos_tddft_file,
        m06_tddft_file=m06_tddft_file,
        dlpno_file=dlpno_file,
        ccsd_s0geom_file=ccsd_s0geom_file,
        ccsd_t1geom_file=ccsd_t1geom_file,
        cores=cores,
    ), executable=True)

    print("\nDone! Workflow summary:")
    print(f"  Submit: {run_file}")
    print(f"  Chain:  S0/T1 opt → freq + TDDFT (parallel) → CCSD(T) + DLPNO")


if __name__ == "__main__":
    main()
